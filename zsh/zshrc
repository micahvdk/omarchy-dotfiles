# ~/.zshrc — sourced for interactive zsh shells.
# Mirrors Omarchy's default bash init (mise, zoxide, fzf) so zsh behaves
# the same as a fresh Omarchy shell. Prompt is rendered by spaceship-prompt
# (installed as an OMZ custom theme by install.sh).

DOTFILES="${DOTFILES:-$HOME/omarchy-dotfiles}"

# ---------- history ----------
HISTFILE="$HOME/.zsh_history"
HISTSIZE=50000
SAVEHIST=50000
setopt APPEND_HISTORY SHARE_HISTORY HIST_IGNORE_DUPS HIST_IGNORE_SPACE \
       HIST_REDUCE_BLANKS INC_APPEND_HISTORY EXTENDED_HISTORY

# ---------- shell options ----------
setopt AUTO_CD AUTO_PUSHD PUSHD_IGNORE_DUPS EXTENDED_GLOB INTERACTIVE_COMMENTS
unsetopt BEEP

# ---------- oh-my-zsh ----------
# Prompt is spaceship-prompt, installed as an OMZ custom theme by install.sh.
# SPACESHIP_* variables must be set before the theme loads, so source the
# spaceship config file before oh-my-zsh.sh below.
export ZSH="$HOME/.oh-my-zsh"
ZSH_THEME="spaceship"
DISABLE_AUTO_UPDATE="true"
plugins=(
  git
  kubectl
  gh
  docker
  tmux
  sudo
  archlinux
  command-not-found
  colored-man-pages
  history-substring-search
  extract
)

[[ -r "$DOTFILES/spaceship/spaceship.zsh" ]] && source "$DOTFILES/spaceship/spaceship.zsh"

if [[ -r "$ZSH/oh-my-zsh.sh" ]]; then
  source "$ZSH/oh-my-zsh.sh"
else
  autoload -Uz compinit && compinit -d "${XDG_CACHE_HOME:-$HOME/.cache}/zcompdump"
fi

zstyle ':completion:*' menu select
zstyle ':completion:*' matcher-list 'm:{a-zA-Z}={A-Za-z}'

# ---------- keybindings ----------
bindkey -e
bindkey '^[[A' history-substring-search-up   2>/dev/null || bindkey '^[[A' up-line-or-history
bindkey '^[[B' history-substring-search-down 2>/dev/null || bindkey '^[[B' down-line-or-history

# ---------- user config ----------
for f in "$DOTFILES"/zsh/env.zsh \
         "$DOTFILES"/zsh/aliases.zsh \
         "$DOTFILES"/zsh/functions.zsh \
         "$DOTFILES"/zsh/secret.zsh; do
  [[ -r "$f" ]] && source "$f"
done

# ---------- tool integrations (match Omarchy default bash init) ----------
if command -v mise &>/dev/null; then
  eval "$(mise activate zsh)"
fi

if command -v fnox &>/dev/null; then
  eval "$(fnox activate zsh)"
fi

if command -v zoxide &>/dev/null; then
  eval "$(zoxide init zsh)"
fi

if command -v fzf &>/dev/null; then
  [[ -f /usr/share/fzf/completion.zsh ]]   && source /usr/share/fzf/completion.zsh
  [[ -f /usr/share/fzf/key-bindings.zsh ]] && source /usr/share/fzf/key-bindings.zsh
fi

# ---------- plugins (pacman-installed) ----------
for plugin in \
  /usr/share/zsh/plugins/zsh-autosuggestions/zsh-autosuggestions.zsh \
  /usr/share/zsh/plugins/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh; do
  [[ -r "$plugin" ]] && source "$plugin"
done

# ---------- tmux auto-attach ----------
# Start tmux automatically for interactive terminals: attach to an existing
# session named "main" or create one. Skip inside tmux, over SSH, in VS Code,
# in dumb terminals, and when NO_TMUX is set.
if [[ $- == *i* ]] \
   && [[ -z "${TMUX:-}" ]] \
   && [[ -z "${SSH_CONNECTION:-}" ]] \
   && [[ -z "${VSCODE_INJECTION:-}" ]] \
   && [[ -z "${NO_TMUX:-}" ]] \
   && [[ ${TERM:-} != "dumb" ]] \
   && command -v tmux &>/dev/null; then
  exec tmux new-session -A -s main
fi
