#!/usr/bin/env bash
#
# push-secret — upload a local secret into Bitwarden/Vaultwarden via rbw.
#
# Companion to bin/bootstrap-secrets: this is the "first time" path for
# seeding a vault from a machine that already has the secrets on disk.
#
# Stores items as Secure Notes (or Logins for short single-line tokens),
# matching the layout that bootstrap-secrets expects.
#
# Usage:
#   push-secret note  <name> <file>      # Secure Note, body = file contents
#   push-secret token <name> [-]         # Login, password from stdin (or prompt)
#   push-secret ssh                      # ssh-id_ed25519 from ~/.ssh/id_ed25519
#   push-secret age                      # age-key from ~/.config/age/keys.txt
#   push-secret github                   # GITHUB_TOKEN, prompts (no echo)
#   push-secret env   <file>             # environment-variables (KEY=VALUE lines)
#
# Examples:
#   push-secret ssh
#   push-secret github
#   push-secret note ssh-id_ed25519 ~/.ssh/id_ed25519
#   echo "$TOKEN" | push-secret token GITHUB_TOKEN -
#
# If the item already exists, you'll be prompted; pass --force to overwrite.

set -euo pipefail

force=0
args=()
for a in "$@"; do
  case "$a" in
    --force) force=1 ;;
    -h|--help) sed -n '2,30p' "$0"; exit 0 ;;
    *) args+=("$a") ;;
  esac
done
set -- "${args[@]}"

log()  { printf '\033[1;34m==>\033[0m %s\n' "$*"; }
warn() { printf '\033[1;33m!!!\033[0m %s\n' "$*" >&2; }
die()  { printf '\033[1;31mxxx\033[0m %s\n' "$*" >&2; exit 1; }

command -v rbw >/dev/null || die "rbw not installed (yay -S rbw)"

rbw unlock
rbw sync

# True if an item with this exact name already exists in the vault.
item_exists() {
  rbw list --fields name 2>/dev/null | grep -Fxq "$1"
}

confirm_overwrite() {
  local name="$1"
  if [[ $force -eq 1 ]]; then return 0; fi
  read -r -p "Item '$name' already exists. Overwrite? [y/N] " ans
  [[ "$ans" =~ ^[Yy]$ ]]
}

# rbw add/edit open $EDITOR on a tempfile. First line = password, rest = notes.
# We swap EDITOR for a tiny helper that just copies our prepared content in.
edit_with_file() {
  local src="$1" cmd="$2" name="$3" user="${4:-}"
  local helper rc=0
  helper="$(mktemp)"
  cat > "$helper" <<EOF
#!/usr/bin/env bash
cat "$src" > "\$1"
EOF
  chmod 700 "$helper"
  if [[ "$cmd" == "add" ]]; then
    if [[ -n "$user" ]]; then
      EDITOR="$helper" VISUAL="$helper" rbw add "$name" "$user" || rc=$?
    else
      EDITOR="$helper" VISUAL="$helper" rbw add "$name" || rc=$?
    fi
  else
    EDITOR="$helper" VISUAL="$helper" rbw edit "$name" || rc=$?
  fi
  rm -f "$helper" "$src"
  return $rc
}

# Push a Secure Note: empty password line + body as notes.
push_note() {
  local name="$1" file="$2"
  [[ -f "$file" ]] || die "file not found: $file"

  local payload
  payload="$(mktemp)"
  # Empty first line = empty password; remainder = notes.
  printf '\n' > "$payload"
  cat "$file" >> "$payload"

  if item_exists "$name"; then
    confirm_overwrite "$name" || { rm -f "$payload"; log "skip $name"; return 0; }
    log "Updating '$name' from $file"
    edit_with_file "$payload" edit "$name"
  else
    log "Creating '$name' from $file"
    edit_with_file "$payload" add "$name"
  fi
}

# Push a Login: password is the token (single line); notes empty.
push_token() {
  local name="$1" source="${2:-}" token=""
  if [[ "$source" == "-" ]]; then
    IFS= read -r token
  elif [[ -n "$source" && -f "$source" ]]; then
    token="$(head -n1 "$source")"
  else
    read -r -s -p "Value for $name: " token; echo
  fi
  [[ -n "$token" ]] || die "empty value for $name"

  local payload
  payload="$(mktemp)"
  printf '%s\n' "$token" > "$payload"

  if item_exists "$name"; then
    confirm_overwrite "$name" || { rm -f "$payload"; log "skip $name"; return 0; }
    log "Updating '$name'"
    edit_with_file "$payload" edit "$name"
  else
    log "Creating '$name'"
    edit_with_file "$payload" add "$name"
  fi
}

cmd="${1:-}"; shift || true
case "$cmd" in
  note)   push_note "${1:?name}" "${2:?file}" ;;
  token)  push_token "${1:?name}" "${2:-}" ;;
  ssh)    push_note "ssh-id_ed25519" "$HOME/.ssh/id_ed25519" ;;
  age)    push_note "age-key" "$HOME/.config/age/keys.txt" ;;
  env)    push_note "environment-variables" "${1:?file}" ;;
  github) push_token "GITHUB_TOKEN" ;;
  ""|-h|--help) sed -n '2,30p' "$0"; exit 0 ;;
  *) die "unknown command: $cmd (try: push-secret --help)" ;;
esac

log "Done."
