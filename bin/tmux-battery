#!/usr/bin/env bash
# tmux-battery βÄî print battery charge with a glyph reflecting state.
# Reads /sys/class/power_supply/BAT* directly so it works without acpi.

set -eu

shopt -s nullglob
batteries=(/sys/class/power_supply/BAT*)
[[ ${#batteries[@]} -gt 0 ]] || exit 0

bat="${batteries[0]}"
cap=$(<"$bat/capacity")
status=$(<"$bat/status")

case "$status" in
  Charging|Full) glyph="σΑ²³" ;;
  *)
    if   (( cap >= 90 )); then glyph="σΑ¹Ι"
    elif (( cap >= 70 )); then glyph="σΑ²¹"
    elif (( cap >= 50 )); then glyph="σΑ¹Ψ"
    elif (( cap >= 30 )); then glyph="σΑ¹Φ"
    elif (( cap >= 15 )); then glyph="σΑ¹Μ"
    else                       glyph="σΑ¹Κ"
    fi
    ;;
esac

printf '%s %s%%\n' "$glyph" "$cap"
