#!/usr/bin/env bash
# bootstrap-secrets — pull secrets from Bitwarden/Vaultwarden via rbw and
# drop them into their canonical locations on disk.
#
# Vault layout (one item per secret, names are hardcoded):
#   GITHUB_TOKEN     password field = GitHub personal access token
#   ssh-id_ed25519   notes field    = OpenSSH ed25519 private key
#   age-key          notes field    = contents of ~/.config/age/keys.txt
#
# Where things land:
#   age-key       → ~/.config/age/keys.txt           (mode 600)
#   ssh key       → ~/.ssh/id_ed25519 (+ .pub)        (mode 600 / 644)
#   GITHUB_TOKEN  → ~/.config/fnox/config.toml as an age-encrypted secret,
#                   auto-exported in every shell by `fnox activate zsh`.
#
# rbw uses the gnome-keyring that install.sh already wires up, so once
# you've unlocked the vault on this machine it stays unlocked across
# shells until logout / lock.
#
# Usage:
#   ./bin/bootstrap-secrets          # skip files that already exist
#   ./bin/bootstrap-secrets --force  # overwrite anything already on disk

set -euo pipefail

DOTFILES="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

force=0
while (( $# )); do
  case "$1" in
    -f|--force) force=1 ;;
    -h|--help)  sed -n '2,18p' "$0"; exit 0 ;;
    *) printf 'unknown arg: %s\n' "$1" >&2; exit 2 ;;
  esac
  shift
done

log()  { printf '\033[1;34m==>\033[0m %s\n' "$*"; }
warn() { printf '\033[1;33m!!>\033[0m %s\n' "$*" >&2; }
die()  { printf '\033[1;31mxxx\033[0m %s\n' "$*" >&2; exit 1; }

command -v rbw >/dev/null || die "rbw is not installed. Run ./install.sh first."

# First-run config: prompt for email and (optionally) Vaultwarden URL.
if ! rbw config show 2>/dev/null | grep -Eq '^email: [^[:space:]]+$'; then
  log "Configuring rbw"
  read -rp "Bitwarden email: " bw_email
  [[ -n "$bw_email" ]] || die "email is required"
  rbw config set email "$bw_email"
  read -rp "Vaultwarden base URL (blank for bitwarden.com): " bw_url
  [[ -n "$bw_url" ]] && rbw config set base_url "$bw_url"
fi

log "Unlocking vault"
rbw unlock

# Fetch the notes field of an item. We try `--field notes` first (recent
# rbw) and fall back to `--raw` + jq on older builds.
fetch_notes() {
  local name="$1" out
  if out="$(rbw get --field notes "$name" 2>/dev/null)" && [[ -n "$out" ]]; then
    printf '%s' "$out"
    return 0
  fi
  if command -v jq >/dev/null; then
    rbw get --raw "$name" | jq -r '.notes // empty'
    return 0
  fi
  die "could not read notes for '$name' (need newer rbw or jq installed)"
}

write_secret() {
  local path="$1" content="$2" mode="$3"
  if [[ -e "$path" && $force -eq 0 ]]; then
    log "skip $path (exists; pass --force to overwrite)"
    return
  fi
  mkdir -p "$(dirname "$path")"
  umask 077
  # Ensure trailing newline for nicer diffs / POSIX-friendly files.
  printf '%s\n' "$content" > "$path"
  chmod "$mode" "$path"
  log "wrote $path"
}

# ---------- age key → ~/.config/age/keys.txt (must come first) ----------
log "Fetching age-key"
age_content="$(fetch_notes age-key)"
[[ -n "$age_content" ]] || die "age-key notes are empty"
write_secret "$HOME/.config/age/keys.txt" "$age_content" 600

age_key_file="$HOME/.config/age/keys.txt"
[[ -f "$age_key_file" ]] || die "age key file is missing at $age_key_file"
age_pub="$(grep -m1 '# public key:' "$age_key_file" | awk '{print $NF}')"
[[ -n "$age_pub" ]] || die "could not parse '# public key:' from $age_key_file"
export FNOX_AGE_KEY_FILE="$age_key_file"

# ---------- SSH private key → ~/.ssh/id_ed25519 (+ derived .pub) ----------
log "Fetching ssh-id_ed25519"
ssh_priv="$(fetch_notes ssh-id_ed25519)"
[[ -n "$ssh_priv" ]] || die "ssh-id_ed25519 notes are empty"
write_secret "$HOME/.ssh/id_ed25519" "$ssh_priv" 600

if [[ -f "$HOME/.ssh/id_ed25519" ]] && command -v ssh-keygen >/dev/null; then
  if [[ ! -f "$HOME/.ssh/id_ed25519.pub" || $force -eq 1 ]]; then
    if ssh-keygen -y -f "$HOME/.ssh/id_ed25519" > "$HOME/.ssh/id_ed25519.pub.tmp" 2>/dev/null; then
      mv "$HOME/.ssh/id_ed25519.pub.tmp" "$HOME/.ssh/id_ed25519.pub"
      chmod 644 "$HOME/.ssh/id_ed25519.pub"
      log "derived $HOME/.ssh/id_ed25519.pub"
    else
      rm -f "$HOME/.ssh/id_ed25519.pub.tmp"
      warn "could not derive public key (key may be passphrase-protected)"
    fi
  fi
fi

# ---------- fnox global config (age provider) ----------
fnox_config="$HOME/.config/fnox/config.toml"
if [[ ! -f "$fnox_config" ]]; then
  log "Creating fnox global config at $fnox_config"
  mkdir -p "$(dirname "$fnox_config")"
  umask 077
  cat > "$fnox_config" <<EOF
# fnox global config — auto-loaded into every shell by \`fnox activate zsh\`.
# Generated by bin/bootstrap-secrets; safe to edit.
# Decryption requires FNOX_AGE_KEY_FILE (set in zsh/env.zsh).

[providers.age]
type = "age"
recipients = ["$age_pub"]
EOF
  chmod 600 "$fnox_config"
elif ! grep -q '^\[providers\.age\]' "$fnox_config"; then
  log "Appending age provider to $fnox_config"
  printf '\n[providers.age]\ntype = "age"\nrecipients = ["%s"]\n' "$age_pub" >> "$fnox_config"
fi

command -v fnox >/dev/null || die "fnox is not installed. Run ./install.sh first."

# ---------- GITHUB_TOKEN → fnox (age-encrypted) ----------
log "Fetching GITHUB_TOKEN"
gh_token="$(rbw get GITHUB_TOKEN)"
[[ -n "$gh_token" ]] || die "GITHUB_TOKEN item is empty"

# Strip any legacy plaintext export from secret.zsh — fnox owns this now.
secret_file="$DOTFILES/zsh/secret.zsh"
if [[ -f "$secret_file" ]] && grep -q '^export GITHUB_TOKEN=' "$secret_file"; then
  log "Removing legacy GITHUB_TOKEN export from $secret_file"
  awk '!/^export GITHUB_TOKEN=/' "$secret_file" > "$secret_file.tmp"
  mv "$secret_file.tmp" "$secret_file"
  chmod 600 "$secret_file"
fi

log "Encrypting GITHUB_TOKEN into $fnox_config (provider: age)"
# Pipe via stdin so the token never appears in argv / shell history.
printf '%s' "$gh_token" | fnox set --global --provider age GITHUB_TOKEN
log "GITHUB_TOKEN stored. It will be auto-exported by 'fnox activate zsh'."

log "Done. Open a new shell (or 'exec zsh') to pick up GITHUB_TOKEN via fnox."
