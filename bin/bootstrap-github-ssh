#!/usr/bin/env bash
# Bootstrap SSH authentication with GitHub.
#
# - Generates an ed25519 key at ~/.ssh/id_ed25519 if missing.
# - Starts ssh-agent (if not already running) and adds the key.
# - Uploads the public key to your GitHub account via `gh`.
# - Verifies the SSH connection.
#
# Idempotent: safe to run multiple times.

set -euo pipefail

log()  { printf '\033[1;34m==>\033[0m %s\n' "$*"; }
warn() { printf '\033[1;33m!!>\033[0m %s\n' "$*" >&2; }
die()  { printf '\033[1;31mxxx\033[0m %s\n' "$*" >&2; exit 1; }

command -v ssh-keygen >/dev/null || die "openssh not installed"
command -v gh         >/dev/null || die "github-cli (gh) not installed"

KEY="$HOME/.ssh/id_ed25519"
PUB="$KEY.pub"
TITLE="${1:-$(hostname)-$(date +%Y%m%d)}"

mkdir -p "$HOME/.ssh"
chmod 700 "$HOME/.ssh"

if [[ ! -f "$KEY" ]]; then
  log "Generating ed25519 key at $KEY"
  read -r -p "Email for the key (used as comment): " email
  ssh-keygen -t ed25519 -C "$email" -f "$KEY"
else
  log "Key already exists at $KEY — reusing"
fi

if [[ -z "${SSH_AUTH_SOCK:-}" ]] || ! ssh-add -l &>/dev/null; then
  log "Starting ssh-agent"
  eval "$(ssh-agent -s)" >/dev/null
fi

KEY_FP="$(ssh-keygen -lf "$PUB" | awk '{print $2}')"
if ! ssh-add -l 2>/dev/null | grep -qF "$KEY_FP"; then
  log "Adding key to ssh-agent"
  ssh-add "$KEY"
fi

if ! gh auth status &>/dev/null; then
  log "Authenticating gh (choose SSH when prompted for git protocol)"
  gh auth login --git-protocol ssh --hostname github.com --web
fi

PUB_KEY_BODY="$(awk '{print $2}' "$PUB")"
if gh ssh-key list 2>/dev/null | grep -qF "$PUB_KEY_BODY"; then
  log "Public key already uploaded to GitHub"
else
  log "Uploading public key to GitHub as '$TITLE'"
  gh ssh-key add "$PUB" --title "$TITLE"
fi

log "Verifying SSH connection to github.com"
if ssh -o StrictHostKeyChecking=accept-new -T git@github.com 2>&1 | grep -q "successfully authenticated"; then
  log "✅ GitHub SSH authentication working."
else
  warn "Could not verify GitHub SSH connection. Run: ssh -T git@github.com"
fi
